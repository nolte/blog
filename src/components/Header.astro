---
import { useTranslations, type UiKey } from "~/i18n/ui";
import type { Locale } from "~/consts";
import { SITE } from "~/consts";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const link = (path: string, l: Locale) => {
  const prefix = l === "en" ? "" : `/${l}`;
  return `${base}${prefix}${path}`;
};

const otherLang: Locale = lang === "en" ? "de" : "en";
const currentPath = Astro.url.pathname
  .replace(new RegExp(`^${base}`), "")
  .replace(/^\/(en|de)(?=\/|$)/, "") || "/";

const nav: { key: UiKey; href: string }[] = [
  { key: "nav.home", href: link("/", lang) },
  { key: "nav.blog", href: link("/blog", lang) },
  { key: "nav.projects", href: link("/projects", lang) },
  { key: "nav.about", href: link("/about", lang) },
];
---

<header class="border-b border-zinc-200 bg-white/80 backdrop-blur dark:border-zinc-800 dark:bg-zinc-950/80 sticky top-0 z-10">
  <div class="mx-auto flex max-w-3xl items-center justify-between px-4 py-4">
    <a href={link("/", lang)} class="font-mono text-sm font-semibold tracking-tight hover:opacity-70">
      {SITE.title}
    </a>
    <nav class="flex items-center gap-4 text-sm">
      {nav.map((item) => (
        <a href={item.href} class="hover:underline">{t(item.key)}</a>
      ))}
      <a
        href={link(currentPath, otherLang)}
        class="rounded border border-zinc-300 px-2 py-0.5 text-xs font-mono hover:bg-zinc-100 dark:border-zinc-700 dark:hover:bg-zinc-900"
        aria-label={`Switch to ${otherLang.toUpperCase()}`}
      >
        {otherLang.toUpperCase()}
      </a>
    </nav>
  </div>
</header>
