---
import { useTranslations } from "~/i18n/ui";
import type { Locale } from "~/consts";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const rss = lang === "en" ? `${base}/rss.xml` : `${base}/de/rss.xml`;
---

<footer class="mt-16 border-t border-zinc-200 dark:border-zinc-800">
  <div class="mx-auto flex max-w-3xl items-center justify-between px-4 py-6 text-xs text-zinc-600 dark:text-zinc-400">
    <span>{t("footer.builtWith")}</span>
    <a href={rss} class="hover:underline" rel="alternate" type="application/rss+xml">{t("nav.rss")}</a>
  </div>
</footer>
