---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { useTranslations } from "~/i18n/ui";

const lang = "en" as const;
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout title="404" lang={lang}>
  <div class="py-16 text-center">
    <p class="font-mono text-sm text-zinc-500">404</p>
    <h1 class="mt-3 text-3xl font-bold">{t("404.title")}</h1>
    <p class="mt-2 text-zinc-600 dark:text-zinc-400">{t("404.body")}</p>
    <a href={`${base}/`} class="mt-6 inline-block underline">{t("404.home")}</a>
  </div>
</BaseLayout>
