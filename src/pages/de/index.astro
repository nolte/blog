---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { useTranslations } from "~/i18n/ui";
import { SITE } from "~/consts";

const lang = "de" as const;
const t = useTranslations(lang);

const posts = (await getCollection("posts", ({ data }) => data.lang === lang && !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const postHref = (id: string) => `${base}/de/blog/${id.replace(/^de\//, "")}`;
---

<BaseLayout lang={lang}>
  <section class="mb-12">
    <h1 class="text-4xl font-bold tracking-tight">{SITE.title}</h1>
    <p class="mt-3 text-zinc-600 dark:text-zinc-400">{SITE.description.de}</p>
  </section>

  <section>
    <h2 class="mb-4 text-xl font-semibold">{t("list.latestPosts")}</h2>
    {posts.length === 0 ? (
      <p class="text-zinc-600 dark:text-zinc-400">{t("list.noPosts")}</p>
    ) : (
      <ul class="space-y-6">
        {posts.map((p) => (
          <li>
            <a href={postHref(p.id)} class="group block">
              <h3 class="text-lg font-medium group-hover:underline">{p.data.title}</h3>
              <p class="text-sm text-zinc-600 dark:text-zinc-400">{p.data.description}</p>
              <time class="text-xs text-zinc-500" datetime={p.data.pubDate.toISOString()}>
                {p.data.pubDate.toLocaleDateString("de-DE", { year: "numeric", month: "long", day: "numeric" })}
              </time>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>
