---
import "~/styles/global.css";
import Header from "~/components/Header.astro";
import Footer from "~/components/Footer.astro";
import { SITE } from "~/consts";
import type { Locale } from "~/consts";

interface Props {
  title?: string;
  description?: string;
  lang: Locale;
  ogImage?: string;
}

const { title, description, lang, ogImage } = Astro.props;
const fullTitle = title ? `${title} — ${SITE.title}` : SITE.title;
const desc = description ?? SITE.description[lang];
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalURL} />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={lang === "de" ? "de_DE" : "en_US"} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE.title}
      href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}${lang === "en" ? "" : "/de"}/rss.xml`}
    />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header lang={lang} />
    <main class="mx-auto w-full max-w-3xl flex-1 px-4 py-10">
      <slot />
    </main>
    <Footer lang={lang} />
    {/*
      Dev-only client-side Mermaid renderer. In `astro dev` the rehype-mermaid
      plugin runs with strategy `pre-mermaid` (see astro.config.mjs) and leaves
      the source as `<pre class="mermaid">`. This loader renders those blocks
      in the browser so the diagram is visible during local authoring.
      In `astro build` `import.meta.env.DEV` is `false`, Vite tree-shakes this
      branch out, and the production HTML carries inline SVGs only — no
      runtime JS, no mermaid bundle.
    */}
    {import.meta.env.DEV && (
      <script>
        import("mermaid").then(({ default: mermaid }) => {
          mermaid.initialize({ startOnLoad: true });
        });
      </script>
    )}
  </body>
</html>
